---
import Layout from "../../layouts/Layout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { supabase } from "../../lib/supabaseClient";

export async function getStaticPaths() {
    const { data: categories } = await supabase
        .from("categories")
        .select("slug");
    return categories?.map((cat) => ({ params: { slug: cat.slug } })) || [];
}

const { slug: rawSlug } = Astro.params;
const slug = rawSlug?.trim().toLowerCase();

// Fetch category data
const { data: categoryData } = await supabase
    .from("categories")
    .select("name, description")
    .eq("slug", slug)
    .single();

if (!categoryData) {
    return Astro.redirect("/404");
}

const { name, description } = categoryData;

const { data: rawArticles } = await supabase
    .from("posts")
    .select("*")
    .eq("status", "published")
    .ilike("category", name) // Apenas artigos onde category = name
    .order("published_at", { ascending: false })
    .limit(48);

const articles =
    rawArticles?.map((post) => ({
        ...post,
        featuredImage: post.image_url,
        featuredImageAlt: post.image_alt,
        publishedAt: post.published_at,
        author: post.author_name,
    })) || [];
---

<Layout
    title={`${name} | Blog.`}
    description={description || `Veja todos os artigos sobre ${name}`}
>
    <div class="bg-white border-b border-gray-100 py-16 mb-12">
        <div class="blog-container text-center">
            <h1
                class="text-4xl md:text-5xl font-black text-gray-900 mb-4 capitalize"
            >
                {name}
            </h1>
            {
                description && (
                    <p class="text-lg text-gray-500 max-w-2xl mx-auto">
                        {description}
                    </p>
                )
            }
            <div class="mt-6">
                <span
                    class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-semibold bg-[#FFE600] text-[#2D3277]"
                >
                    {articles?.length || 0} Artigos
                </span>
            </div>
        </div>
    </div>

    <div class="blog-container pb-24">
        {
            articles && articles.length > 0 ? (
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
                    {articles.map((article) => (
                        <ArticleCard article={article} />
                    ))}
                </div>
            ) : (
                <div class="bg-gray-50 rounded-xl p-16 text-center text-gray-500 border border-gray-200">
                    Nenhum artigo encontrado nesta categoria.
                </div>
            )
        }
    </div>
</Layout>
