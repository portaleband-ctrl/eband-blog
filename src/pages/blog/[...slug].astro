---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { optimizeRemoteImage } from "../../lib/imageUtils";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);

const optimizedHero = post.data.heroImage
	? optimizeRemoteImage(post.data.heroImage, 1100, 80)
	: null;
---

<Layout
	title={`${post.data.title} | Blog.`}
	description={post.data.description}
	image={optimizedHero || post.data.heroImage}
>
	<article class="ai-article-container pb-24">
		<header
			class="bg-white border-b border-gray-100 pt-10 pb-12 mb-12 relative overflow-hidden"
		>
			<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
				<div class="flex items-center gap-2 text-sm mb-6">
					<a href="/" class="text-gray-400 hover:text-[#3483FA]"
						>Início</a
					>
					<span class="text-gray-300">/</span>
					<a
						href="/blog"
						class="text-[#3483FA] font-medium hover:underline"
						>Blog</a
					>
				</div>

				<h1
					class="text-3xl md:text-5xl font-black text-gray-900 leading-tight mb-8 tracking-tight"
				>
					{post.data.title}
				</h1>

				<div
					class="flex items-center gap-4 text-sm text-gray-500 pb-6 border-b border-gray-200"
				>
					<span class="font-medium text-gray-700"
						>Por Equipe Editorial</span
					>
					<span class="w-1 h-1 rounded-full bg-gray-300"></span>
					<span
						>{
							post.data.pubDate.toLocaleDateString("pt-BR", {
								day: "numeric",
								month: "long",
								year: "numeric",
							})
						}</span
					>
				</div>
			</div>
		</header>

		<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
			{
				post.data.heroImage && (
					<div class="relative rounded-2xl overflow-hidden shadow-lg mb-12 aspect-[16/9] bg-gray-100">
						<Image
							src={optimizedHero || post.data.heroImage}
							alt={post.data.title}
							width={1100}
							height={619}
							class="w-full h-full object-cover"
							loading="eager"
							fetchpriority="high"
						/>
					</div>
				)
			}

			<div class="prose-blog">
				<Content />
			</div>
		</div>
	</article>
</Layout>
