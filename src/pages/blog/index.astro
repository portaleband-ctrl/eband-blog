---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { optimizeRemoteImage } from "../../lib/imageUtils";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Arquivo do Blog | Blog.">
	<div class="blog-container py-12">
		<h1
			class="text-3xl md:text-5xl font-black text-gray-900 leading-tight mb-12 tracking-tight"
		>
			Arquivo do <span class="text-[#3483FA]">Blog</span>
		</h1>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			{
				posts.map((post, index) => {
					const optimizedHero = post.data.heroImage
						? optimizeRemoteImage(post.data.heroImage, 800, 80)
						: null;
					return (
						<a
							href={`/blog/${post.id}/`}
							class="group block bg-white rounded-xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition-all"
						>
							<div class="aspect-[16/9] overflow-hidden">
								{post.data.heroImage && (
									<Image
										width={800}
										height={450}
										src={
											optimizedHero || post.data.heroImage
										}
										alt={post.data.title}
										class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										loading={index < 2 ? "eager" : "lazy"}
									/>
								)}
							</div>
							<div class="p-6">
								<p class="text-xs text-gray-400 font-bold mb-2 uppercase tracking-widest">
									{post.data.pubDate.toLocaleDateString(
										"pt-BR",
										{
											day: "numeric",
											month: "long",
											year: "numeric",
										},
									)}
								</p>
								<h2 class="text-xl font-bold text-gray-900 group-hover:text-[#3483FA] transition-colors leading-tight">
									{post.data.title}
								</h2>
								<p class="text-gray-500 text-sm mt-3 line-clamp-2">
									{post.data.description}
								</p>
							</div>
						</a>
					);
				})
			}
		</div>
	</div>
</Layout>
