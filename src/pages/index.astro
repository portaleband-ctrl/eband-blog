---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { supabase } from "../lib/supabaseClient";

// Cache na Borda (Cloudflare)
Astro.response.headers.set(
	"Cache-Control",
	"public, s-maxage=60, stale-while-revalidate=30",
);

// Server-side Data Fetching - Roda apenas no servidor = SEO Perfeito
const { data: rawArticles } = await supabase
	.from("posts")
	.select("*")
	.eq("status", "published")
	.order("published_at", { ascending: false })
	.limit(48);

const articles =
	rawArticles?.map((post) => ({
		...post,
		featuredImage: post.image_url,
		featuredImageAlt: post.image_alt,
		publishedAt: post.published_at,
		author: post.author_name,
	})) || [];

const { data: categories } = await supabase
	.from("categories")
	.select("*")
	.order("name");

const featuredCategories = categories?.filter((c) => c.featured) || [];
const displayCategories =
	featuredCategories.length > 0
		? featuredCategories
		: categories?.slice(0, 8) || [];

const mainArticles = articles || [];
const featuredArticle = mainArticles.length > 0 ? mainArticles[0] : null;
const recentArticles = mainArticles.slice(1);
---

<Layout title="Home | Melhores Análises e Recomendações">
	<!-- Categories Navbar -->
	<div
		class="bg-white border-b sticky top-[72px] z-40 hidden md:block shadow-sm"
	>
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div
				class="flex items-center gap-1.5 py-3 overflow-x-auto no-scrollbar"
			>
				<a
					href="/"
					class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold bg-[#3483FA]/10 text-[#3483FA] border border-[#3483FA] whitespace-nowrap"
				>
					Início
				</a>

				{
					displayCategories.map((cat) => (
						<a
							href={`/categoria/${cat.slug}`}
							class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-semibold bg-white border border-gray-300 text-gray-700 hover:border-[#3483FA] hover:text-[#3483FA] transition-all whitespace-nowrap"
						>
							{cat.name}
						</a>
					))
				}

				<a
					href="/categorias"
					class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-semibold bg-gray-50 border border-gray-200 text-gray-600 hover:bg-gray-100 transition-all whitespace-nowrap ml-1"
				>
					Ver todas
				</a>
			</div>
		</div>
	</div>

	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
		<!-- Featured Article Section -->
		<div class="mb-16">
			<div class="flex items-center justify-between mb-8">
				<h2
					class="text-3xl font-black text-gray-900 tracking-tight flex items-center gap-3"
				>
					Destaque
					<span
						class="w-2 h-2 rounded-full bg-[#FFE600] animate-pulse"
					></span>
				</h2>
			</div>

			{
				featuredArticle ? (
					<ArticleCard article={featuredArticle} featured={true} />
				) : (
					<div class="bg-gray-50 rounded-xl p-8 text-center text-gray-500 border border-gray-200">
						Nenhum artigo publicado ainda.
					</div>
				)
			}
		</div>

		<!-- Recent Articles Section -->
		<div class="mb-8">
			<div class="flex items-center justify-between mb-8">
				<h2
					class="text-2xl md:text-3xl font-black text-gray-900 tracking-tight"
				>
					Mais <span class="text-[#3483FA]">Recentes</span>
				</h2>
			</div>

			{
				recentArticles.length > 0 ? (
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
						{recentArticles.map((article) => (
							<ArticleCard article={article} />
						))}
					</div>
				) : null
			}

			<div class="mt-16 text-center">
				<a
					href="/noticias/2"
					class="inline-flex items-center px-8 py-3 bg-white border border-gray-200 text-[#3483FA] font-bold rounded-full hover:bg-[#3483FA] hover:text-white transition-all shadow-sm group"
				>
					Ver todas as notícias
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="ml-2 group-hover:translate-x-1 transition-transform"
						><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
						></path></svg
					>
				</a>
			</div>
		</div>
	</div>
</Layout>
