---
import Layout from "../../layouts/Layout.astro";
import { supabase } from "../../lib/supabaseClient";
import { Calendar, Tag } from "lucide-react";
import { Image } from "astro:assets";

export const prerender = false;

const { slug: rawSlug } = Astro.params;
const slug = rawSlug?.trim().toLowerCase();

// Cache na Borda (Cloudflare):
Astro.response.headers.set(
    "Cache-Control",
    "public, s-maxage=31536000, stale-while-revalidate=60",
);

const { data: rawArticle } = await supabase
    .from("posts")
    .select("*")
    .eq("slug", slug)
    .single();

if (!rawArticle) {
    return Astro.redirect("/404");
}

let featuredImage = rawArticle.image_url;
if (featuredImage && featuredImage.includes("eband.com.br/wp-content")) {
    featuredImage = featuredImage.replace(
        "eband.com.br",
        "site-eband-wordpress-eband.mftikx.easypanel.host",
    );
}

if (featuredImage && featuredImage.startsWith("http:")) {
    featuredImage = featuredImage.replace("http:", "https:");
} else if (featuredImage && featuredImage.startsWith("//")) {
    featuredImage = "https:" + featuredImage;
}

const article = {
    ...rawArticle,
    featuredImage: featuredImage,
    featuredImageAlt: rawArticle.image_alt,
    publishedAt: rawArticle.published_at,
    author: rawArticle.author_name,
};

let finalContent = article.content;
finalContent = finalContent.replace(
    /<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi,
    "",
);

const dateFormatted = new Date(article.publishedAt).toLocaleDateString(
    "pt-BR",
    {
        day: "numeric",
        month: "long",
        year: "numeric",
    },
);
---

<Layout
    title={`${article.title} | Blog.`}
    description={article.excerpt}
    image={article.featuredImage}
>
    <article class="ai-article-container pb-24">
        <!-- Header Hero Section -->
        <header
            class="bg-white border-b border-gray-100 pt-10 pb-12 mb-12 relative overflow-hidden"
        >
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <!-- Breadcrumb / Category -->
                <div class="flex items-center gap-2 text-sm mb-6">
                    <a
                        href="/"
                        class="text-gray-400 hover:text-[#3483FA] transition-colors"
                        >Início</a
                    >
                    <span class="text-gray-300">/</span>
                    <a
                        href={`/categoria/${article.category?.toLowerCase()}`}
                        class="text-[#3483FA] font-medium hover:underline capitalize"
                        >{article.category}</a
                    >
                </div>

                <h1
                    class="text-3xl md:text-5xl lg:text-5xl font-black text-gray-900 leading-tight mb-8 tracking-tight"
                >
                    {article.title}
                </h1>

                <!-- Meta: Author & Date -->
                <div
                    class="flex flex-wrap items-center gap-4 text-sm text-gray-500 pb-6 border-b border-gray-200"
                >
                    <span class="flex items-center gap-1.5">
                        <div
                            class="w-7 h-7 rounded-full bg-[#3483FA] flex items-center justify-center text-white text-xs font-bold"
                        >
                            {article.author ? article.author.charAt(0) : "E"}
                        </div>
                        <span class="font-medium text-gray-700"
                            >{article.author || "Equipe Editorial"}</span
                        >
                    </span>
                    <span class="flex items-center gap-1.5">
                        <Calendar className="w-4 h-4" />
                        {dateFormatted}
                    </span>
                </div>
            </div>
        </header>

        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Featured Image -->
            <div
                class="relative rounded-2xl overflow-hidden shadow-lg mb-12 aspect-[16/9] bg-gray-100"
            >
                <img
                    src={article.featuredImage}
                    alt={article.title}
                    class="w-full h-full object-cover"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                    referrerpolicy="no-referrer"
                    crossorigin="anonymous"
                />
            </div>

            <!-- Article Content -->
            <div class="prose-blog" set:html={finalContent} />

            <!-- Tags Section -->
            {
                article.tags && article.tags.length > 0 && (
                    <div class="mt-16 pt-8 border-t border-gray-200">
                        <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                            <Tag className="w-5 h-5 text-[#3483FA]" />
                            Tags
                        </h3>
                        <div class="flex flex-wrap gap-2">
                            {article.tags.map((tag: string) => (
                                <a
                                    href={`/tag/${tag.toLowerCase().replace(/ /g, "-")}`}
                                    class="px-4 py-2 bg-gray-50 hover:bg-[#3483FA]/10 text-gray-600 hover:text-[#3483FA] rounded-full text-sm font-medium transition-colors border border-gray-200 hover:border-[#3483FA]/30"
                                >
                                    {tag}
                                </a>
                            ))}
                        </div>
                    </div>
                )
            }
        </div>
    </article>
</Layout>
