---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { supabase } from "../lib/supabaseClient";
import { getImage } from "astro:assets";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

// Única chamada para settings em todo o layout
const { data: rawSettings } = await supabase
  .from("settings")
  .select("*")
  .single();
const settings = rawSettings?.config;

const {
  title: propTitle,
  description: propDescription,
  image = "/default-og.png",
} = Astro.props;

const blogName = settings?.blogName || "Blog.";
const title = propTitle
  ? `${propTitle}`
  : `${blogName} | ${settings?.blogDescription || "Análises de Produtos"}`;
const description =
  propDescription ||
  settings?.blogDescription ||
  "Análises e recomendações de produtos";
const favicon = settings?.blogFavicon || "/favicon.svg";

const currentUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://eband.com.br",
);

// Sincronizar o Preload com o Proxy de Imagem do Astro
let preloadUrl = image;
if (image && image !== "/default-og.png") {
  try {
    const optimized = await getImage({
      src: image,
      width: 1100,
      height: 619,
      format: "webp",
      quality: 80,
    });
    preloadUrl = optimized.src;
  } catch (e) {
    console.error("Erro ao gerar preload URL:", e);
  }
}
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href={favicon} />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- LCP Preload -->
    {
      preloadUrl && preloadUrl !== "/default-og.png" && (
        <link rel="preload" as="image" href={preloadUrl} fetchpriority="high" />
      )
    }

    <!-- Carregamento Assíncrono de Fontes -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Outfit:wght@700;900&display=swap"
      media="print"
      onload="this.media='all'"
    />

    <!-- Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={currentUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- CSS ULTRA-CRÍTICO INLINE (Substitui o global.css) -->
    <style is:inline>
      :root {
        --blue: #3483fa;
        --dark-blue: #2d3277;
      }
      body {
        background-color: #f5f5f5;
        margin: 0;
        font-family: "Inter", system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        color: #111827;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .blog-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 16px;
        width: 100%;
        box-sizing: border-box;
      }
      header {
        background-color: #ffffff;
        border-bottom: 1px solid #f3f4f6;
        position: sticky;
        top: 0;
        z-index: 50;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
      }
      .h-16 {
        height: 64px;
      }
      .h-20 {
        height: 80px;
      }
      @media (min-width: 768px) {
        .h-20 {
          height: 80px;
        }
      }
      main {
        display: block;
        flex-grow: 1;
      }
      img {
        max-width: 100%;
        height: auto;
        display: block;
        border-radius: 8px;
      }
      .prose-blog {
        max-width: none;
        line-height: 1.625;
        font-size: 1.125rem;
      }
      .prose-blog h2 {
        font-size: 1.875rem;
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 1rem;
        color: #111827;
      }
      .prose-blog p {
        margin-bottom: 1.5rem;
        color: #374151;
      }
      .prose-blog a {
        color: #3483fa;
        text-decoration: none;
      }
      .prose-blog a:hover {
        text-decoration: underline;
      }

      /* Botão ML Style */
      .ai-article-container a[href*="amzn.to"],
      .ai-article-container .btn-offer,
      .ver-oferta-btn {
        display: block !important;
        width: fit-content !important;
        margin: 2rem auto !important;
        background-color: #3483fa !important;
        color: #fff !important;
        padding: 12px 32px !important;
        border-radius: 4px !important;
        font-weight: 700 !important;
        text-decoration: none !important;
        box-shadow: 0 2px 8px rgba(52, 131, 250, 0.3) !important;
        text-align: center !important;
      }

      /* Tabelas */
      .ai-article-container table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
        border: 1px solid #e5e7eb;
        overflow: hidden;
        border-radius: 8px;
      }
      .ai-article-container th {
        background-color: #3483fa;
        color: #fff;
        padding: 12px;
        text-align: left;
      }
      .ai-article-container td {
        padding: 12px;
        border-bottom: 1px solid #f3f4f6;
        background: #fff;
      }
    </style>
  </head>
  <body class="bg-[#F5F5F5] min-h-screen flex flex-col antialiased">
    <Header settings={settings} />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer settings={settings} />
  </body>
</html>
