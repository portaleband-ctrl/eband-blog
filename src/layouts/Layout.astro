---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { supabase } from "../lib/supabaseClient";
import { optimizeRemoteImage } from "../lib/imageUtils";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

// Única chamada para settings em todo o layout
const { data: rawSettings } = await supabase
  .from("settings")
  .select("*")
  .single();
const settings = rawSettings?.config;

const {
  title: propTitle,
  description: propDescription,
  image = "/default-og.png",
} = Astro.props;

const blogName = settings?.blogName || "Blog.";
const title = propTitle
  ? `${propTitle}`
  : `${blogName} | ${settings?.blogDescription || "Análises de Produtos"}`;
const description =
  propDescription ||
  settings?.blogDescription ||
  "Análises e recomendações de produtos";
const favicon = settings?.blogFavicon || "/favicon.svg";

const currentUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://eband.com.br",
);

// Otimizar Imagem LCP para o Preload
// Sincronizado com o ArticleCard e [slug].astro
let preloadUrl = image;
if (image && image !== "/default-og.png") {
  preloadUrl = optimizeRemoteImage(image, 1100, 80);
}
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href={favicon} />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- LCP Preload (Manual Optimization) -->
    {
      preloadUrl && preloadUrl !== "/default-og.png" && (
        <link rel="preload" as="image" href={preloadUrl} fetchpriority="high" />
      )
    }

    <!-- Fonts: Carregamento Assíncrono para evitar bloqueio de renderização -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Outfit:wght@700;900&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Outfit:wght@700;900&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={currentUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- CSS Crítico Inline: Resolve o "Render Blocking CSS" do PageSpeed -->
    <style is:inline>
      :root {
        --blue: #3483fa;
      }
      body {
        background-color: #f5f5f5;
        margin: 0;
        font-family: sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .blog-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 16px;
      }
      header {
        background-color: #ffe600;
        border-bottom: 1px solid #fcd200;
        position: sticky;
        top: 0;
        z-index: 50;
      }
      .h-22 {
        height: 88px;
      }
      img {
        max-width: 100%;
        height: auto;
      }
      .aspect-\[16\/9\] {
        aspect-ratio: 16/9;
      }
      .aspect-\[16\/10\] {
        aspect-ratio: 16/10;
      }
    </style>
  </head>
  <body class="bg-[#F5F5F5] min-h-screen flex flex-col antialiased">
    <Header settings={settings} />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer settings={settings} />
  </body>
</html>
