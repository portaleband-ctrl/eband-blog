---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { supabase } from "../lib/supabaseClient";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { data: rawSettings } = await supabase
  .from("settings")
  .select("*")
  .single();
const settings = rawSettings?.config;

const {
  title: propTitle,
  description: propDescription,
  image = "/default-og.png",
} = Astro.props;

const blogName = settings?.blogName || "Blog.";
const title = propTitle
  ? `${propTitle}`
  : `${blogName} | ${settings?.blogDescription || "Análises de Produtos"}`;
const description =
  propDescription ||
  settings?.blogDescription ||
  "Análises e recomendações de produtos";
const favicon = settings?.blogFavicon || "/favicon.svg";

const currentUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://eband.com.br",
);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href={favicon} />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Outfit:wght@700;900&display=swap"
      rel="stylesheet"
    />

    <!-- Preload LCP Image -->
    {
      image && image !== "/default-og.png" && (
        <link rel="preload" as="image" href={image} fetchpriority="high" />
      )
    }

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={currentUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />
  </head>
  <body class="bg-[#F5F5F5] min-h-screen flex flex-col">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
