---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { supabase } from "../lib/supabaseClient";
import { getImage } from "astro:assets";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

// Única chamada para settings em todo o layout
const { data: rawSettings } = await supabase
  .from("settings")
  .select("*")
  .single();
const settings = rawSettings?.config;

const {
  title: propTitle,
  description: propDescription,
  image = "/default-og.png",
} = Astro.props;

const blogName = settings?.blogName || "Blog.";
const title = propTitle
  ? `${propTitle}`
  : `${blogName} | ${settings?.blogDescription || "Análises de Produtos"}`;
const description =
  propDescription ||
  settings?.blogDescription ||
  "Análises e recomendações de produtos";
const favicon = settings?.blogFavicon || "/favicon.svg";

const currentUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://eband.com.br",
);

// Processo do AdSense
let adSenseClient = "";
if (settings?.googleAdSenseId) {
  if (settings.googleAdSenseId.includes("pub-")) {
    const pubId = settings.googleAdSenseId
      .split("pub-")[1]
      .split(",")[0]
      .trim();
    adSenseClient = `ca-pub-${pubId}`;
  } else {
    adSenseClient = settings.googleAdSenseId; // Caso o usuário já tenha colocado direto o `ca-pub-...`
  }
}

// Usar a URL original da imagem para o og:image e LCP (sem bloqueio de otimização em tempo real)
let preloadUrl = image;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href={favicon} />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- LCP Preload -->
    {
      preloadUrl && preloadUrl !== "/default-og.png" && (
        <link rel="preload" as="image" href={preloadUrl} fetchpriority="high" />
      )
    }

    <!-- Carregamento Assíncrono de Fontes -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Outfit:wght@700;900&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Outfit:wght@700;900&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Google AdSense -->
    {
      adSenseClient && (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adSenseClient}`}
          crossorigin="anonymous"
        />
      )
    }

    <!-- Google Search Console -->
    {
      settings?.googleSearchConsoleCode && (
        <meta
          name="google-site-verification"
          content={settings.googleSearchConsoleCode}
        />
      )
    }

    <!-- Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={currentUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- Estilo Base Crítico para Melhorar FCP -->
    <style is:inline>
      body {
        background-color: #f5f5f5;
        margin: 0;
        -webkit-font-smoothing: antialiased;
        font-family:
          Inter,
          system-ui,
          -apple-system,
          sans-serif;
      }
      .blog-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 16px;
      }
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background-color: #ffe600;
        border-bottom: 1px solid #fcd200;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
      }
    </style>
  </head>
  <body class="bg-[#F5F5F5] min-h-screen flex flex-col antialiased">
    <Header settings={settings} />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer settings={settings} />
  </body>
</html>
