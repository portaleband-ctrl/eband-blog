---
import { supabase } from "../lib/supabaseClient";

const { data: rawSettings } = await supabase
	.from("settings")
	.select("*")
	.single();
const settings = rawSettings?.config;

const currentYear = new Date().getFullYear();
const blogName = settings?.blogName || "Blog.";
const footerText =
	settings?.footerText ||
	"Seu guia confiável para encontrar os melhores produtos. Análises honestas e recomendações baseadas em pesquisa real.";
---

<footer
	class="bg-[#2D3277] text-white pt-16 pb-8 border-t-4 border-[#3483FA] mt-auto"
>
	<div class="blog-container">
		<div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
			<div class="md:col-span-2">
				<a href="/" class="flex items-center gap-2 mb-6">
					<span
						class="text-3xl font-black text-white tracking-tighter"
						>{blogName}</span
					>
				</a>
				<p class="text-gray-300 text-sm leading-relaxed max-w-sm mb-6">
					{footerText}
				</p>
			</div>

			<div>
				<h4
					class="font-bold text-lg mb-4 text-[#FFE600] uppercase tracking-wider text-sm"
				>
					Legal
				</h4>
				<ul class="space-y-3">
					<li>
						<a
							href="/p/sobre"
							class="text-gray-300 hover:text-white transition-colors text-sm flex items-center gap-2 group"
						>
							<span
								class="w-1.5 h-1.5 rounded-full bg-[#3483FA] group-hover:scale-150 transition-transform"
							></span>
							Sobre Nós
						</a>
					</li>
					<li>
						<a
							href="/p/politica-de-privacidade"
							class="text-gray-300 hover:text-white transition-colors text-sm flex items-center gap-2 group"
						>
							<span
								class="w-1.5 h-1.5 rounded-full bg-[#3483FA] group-hover:scale-150 transition-transform"
							></span>
							Política de Privacidade
						</a>
					</li>
					<li>
						<a
							href="/p/termos-de-uso"
							class="text-gray-300 hover:text-white transition-colors text-sm flex items-center gap-2 group"
						>
							<span
								class="w-1.5 h-1.5 rounded-full bg-[#3483FA] group-hover:scale-150 transition-transform"
							></span>
							Termos de Uso
						</a>
					</li>
				</ul>
			</div>

			<div>
				<div
					class="bg-white/10 p-6 rounded-lg border border-white/5 backdrop-blur-sm"
				>
					<h4
						class="font-bold text-white mb-2 flex items-center gap-2"
					>
						Contato
					</h4>
					<p class="text-gray-300 text-sm mb-4">
						Dúvidas ou sugestões? Fale com nossa equipe.
					</p>
					<a
						href="/p/contato"
						class="inline-flex items-center justify-center w-full bg-[#3483FA] hover:bg-[#2968C8] text-white text-sm font-bold py-2.5 px-4 rounded transition-colors"
					>
						Fale Conosco
					</a>
				</div>
			</div>
		</div>

		<div
			class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4"
		>
			<p class="text-xs text-gray-400">
				© {currentYear} Todos os direitos reservados.
			</p>
			<p
				class="text-[10px] text-gray-500 max-w-xl text-center md:text-right"
			>
				Aviso de Afiliado: Participamos de programas de afiliados, como
				o Associados Amazon. Se você comprar por nossos links, podemos
				ganhar uma comissão sem custo adicional para você.
			</p>
		</div>
	</div>
</footer>
