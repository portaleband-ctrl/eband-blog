---
import { supabase } from "../lib/supabaseClient";

const { data: rawSettings } = await supabase
	.from("settings")
	.select("*")
	.single();
const settings = rawSettings?.config;

const blogName = settings?.blogName || "Blog.";
const blogLogo = settings?.blogLogo;
---

<header class="bg-[#FFE600] border-b border-[#FCD200] sticky top-0 z-50">
	<div class="blog-container h-22 flex items-center justify-between py-4">
		<a href="/" class="flex items-center gap-2">
			{
				blogLogo ? (
					<img src={blogLogo} alt={blogName} class="h-10 w-auto" />
				) : (
					<span class="text-3xl font-black text-[#2D3277] tracking-tighter">
						{blogName}
					</span>
				)
			}
		</a>

		<div class="flex items-center gap-6">
			<p class="hidden md:block text-sm font-semibold text-[#2D3277]">
				{settings?.blogDescription || "Recomendamos o melhor para você"}
			</p>

			<div class="flex items-center gap-3">
				<button
					class="w-10 h-10 rounded-full flex items-center justify-center bg-white/50 text-[#2D3277] hover:bg-white transition-colors"
					title="Buscar artigos"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><circle cx="11" cy="11" r="8"></circle><path
							d="m21 21-4.3-4.3"></path></svg
					>
				</button>
			</div>
		</div>
	</div>
</header>
