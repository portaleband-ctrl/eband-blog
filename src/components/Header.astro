---
interface Props {
	settings?: any;
}

const { settings } = Astro.props;

const blogName = settings?.blogName || "Blog.";
const blogLogo = settings?.blogLogo;
---

<header
	class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm transition-all"
>
	<div
		class="blog-container h-16 md:h-20 flex items-center justify-between py-2"
	>
		<a href="/" class="flex items-center gap-2">
			{
				blogLogo ? (
					<img
						src={blogLogo}
						alt={blogName}
						class="h-8 md:h-10 w-auto"
					/>
				) : (
					<span class="text-2xl md:text-3xl font-black text-[#2D3277] tracking-tighter">
						{blogName}
					</span>
				)
			}
		</a>

		<div class="flex items-center gap-6">
			<p
				class="hidden lg:block text-xs font-semibold text-gray-500 uppercase tracking-widest"
			>
				{settings?.blogDescription || "Qualidade em cada review"}
			</p>

			<div class="flex items-center gap-3">
				<button
					class="w-9 h-9 md:w-10 md:h-10 rounded-full flex items-center justify-center bg-gray-50 text-[#2D3277] hover:bg-gray-100 transition-colors"
					title="Buscar"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5"
						stroke-linecap="round"
						stroke-linejoin="round"
						><circle cx="11" cy="11" r="8"></circle><path
							d="m21 21-4.3-4.3"></path></svg
					>
				</button>
			</div>
		</div>
	</div>
</header>
