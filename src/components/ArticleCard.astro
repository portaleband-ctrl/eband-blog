---
import { format } from "date-fns";
import { ptBR } from "date-fns/locale";

interface Props {
    article: {
        id: string;
        title: string;
        slug: string;
        excerpt: string;
        featuredImage: string;
        category: string;
        publishedAt: string;
    };
    featured?: boolean;
}

const { article, featured = false } = Astro.props;

const stripHtml = (html: string) => {
    if (!html) return "";
    return html
        .replace(/<!--[\s\S]*?-->/g, "")
        .replace(/<[^>]*>/g, "")
        .replace(/&nbsp;/g, " ")
        .replace(/&amp;/g, "&")
        .replace(/\s+/g, " ")
        .trim();
};

const cleanTitle = stripHtml(article.title);
const cleanExcerpt = stripHtml(article.excerpt);

const dateFormatted = new Date(article.publishedAt).toLocaleDateString(
    "pt-BR",
    {
        day: "numeric",
    },
);

// Normalizar o slug para evitar erros de roteamento
const slug = article.slug?.trim().toLowerCase() || article.id;
---

<a
    href={`/artigo/${slug}/`}
    class={`group block h-full bg-white rounded-xl overflow-hidden border border-gray-100 hover:border-[#3483FA]/30 transition-all duration-300 ${featured ? "md:flex md:flex-row-reverse shadow-lg" : "shadow-sm hover:shadow-md"}`}
>
    <div
        class={`relative overflow-hidden ${featured ? "md:w-[55%] lg:w-[60%]" : "aspect-[16/10]"}`}
    >
        <div
            class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent z-10"
        >
        </div>
        <img
            src={article.featuredImage}
            alt={article.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out"
            loading={featured ? "eager" : "lazy"}
        />
        <div class="absolute top-4 left-4 z-20">
            <span
                class="inline-block bg-[#FFE600] text-[#2D3277] text-[10px] font-black px-2.5 py-1 rounded-sm uppercase tracking-widest shadow-sm"
            >
                {article.category}
            </span>
        </div>
    </div>

    <div
        class={`p-5 flex flex-col justify-between ${featured ? "md:w-[45%] lg:w-[40%] md:p-8 lg:p-10" : "h-[200px]"}`}
    >
        <div>
            <h3
                class={`font-bold text-gray-900 leading-tight mb-2 group-hover:text-[#3483FA] transition-colors line-clamp-3 ${featured ? "text-2xl md:text-3xl lg:text-4xl mb-4 line-clamp-4" : "text-lg"}`}
            >
                {cleanTitle}
            </h3>
            {
                featured && (
                    <p class="text-gray-500 text-sm md:text-base line-clamp-3 mb-6 leading-relaxed">
                        {cleanExcerpt}
                    </p>
                )
            }
        </div>

        <div
            class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between"
        >
            <span class="text-xs text-gray-400 font-medium"
                >{dateFormatted}</span
            >
            <span
                class="text-xs font-bold text-[#3483FA] group-hover:translate-x-1 transition-transform inline-flex items-center gap-1"
            >
                Ler mais
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                    ></path></svg
                >
            </span>
        </div>
    </div>
</a>
